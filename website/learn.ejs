<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Learn</title>
  <link rel="stylesheet" href="/static/learn.css">
  <link rel="stylesheet" href="/static/std.css">
  <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
</head>
<body>
  <nav>
    <input type="checkbox" name="modus-switch" id="modus-switch" hidden>
    <img src="/images/logo.svg" alt="Logo">
    <div class="modus-dropdown">
      <label for="modus-switch">
        <h1>Learn</h1>
      </label>
      <div class="content-wrapper">
        <ul class="content">
          <li>
            <a href="/quiz">Quiz</a>
          </li>
          <li>
            <a href="/test">Test</a>
          </li>
        </ul>
      </div>
    </div>
    <a class="close-btn" href="/set/new">
      <img src="/images/close.svg" alt="Close">
    </a>
  </nav>
  <main class="learn">
    <div class="flash-card fill">
      <div class="top">
        <h1>Word to translate</h1>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 96 960 960">
          <path
            d="M560 925v-62q97-28 158.5-107.5T780 575q0-101-61-181T560 287v-62q124 28 202 125.5T840 575q0 127-78 224.5T560 925ZM120 696V456h160l200-200v640L280 696H120Zm420 48V407q55 17 87.5 64T660 576q0 57-33 104t-87 64ZM420 408 307 516H180v120h127l113 109V408Zm-94 168Z"/>
        </svg>
      </div>
      <div class="bottom">
        <input type="text" name="translation-input" id="translation-input" placeholder="Type the translation here...">
        <input class="answer correct" type="text" name="correct-translation" id="correct-translation" placeholder="Type the translation here...">
        <div class="buttons">
          <button id="forget-button" class="text">I am stupid</button>
          <button id="translation-button" class="fill">Continue</button>
        </div>
      </div>
    </div>
  </main>
  <script>
    const forgotBtn = document.querySelector("#forget-button");
    const continueBtn = document.querySelector("#translation-button");
    const inp = document.querySelector("#translation-input");

    forgotBtn.onclick = () => {
      inp.disabled = true;
      inp.value = "Right translation";
      inp.className = "correct";
    }

    continueBtn.onclick = () => {
      // Check if true
      const isCorrect = false;
      if (isCorrect) {
        inp.className = "correct";
      } else { 
        const correctInp = document.querySelector("#correct-translation")
        correctInp.classList.add("shown");
        correctInp.value = "Right translation"
        correctInp.disabled = true;
        inp.disabled = true;
        inp.className = "false";
      }
    }
  </script>
</body>
</html>